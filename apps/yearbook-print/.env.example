# Copy to .env and use the same values as EXPO_PUBLIC_FIREBASE_* in the main Keepsy app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: if Firebase App Check is enforced for Authentication on web.
VITE_FIREBASE_APPCHECK_SITE_KEY=
# For localhost dev: true (auto-generated) or paste a specific debug token from Firebase App Check.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=true
