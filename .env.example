# Copy to `.env` in the project root, then restart Expo (`npx expo start`).

# Firebase (required)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# OpenAI (optional) — enables AI yearbook cover + profile portrait options in the app.
# Get a key: https://platform.openai.com/api-keys
# You need API billing enabled; ChatGPT Plus is separate from the API.
EXPO_PUBLIC_OPENAI_API_KEY=

# Optional — install / smart-link page (App Store + Play). Defaults to https://keepsy.app
EXPO_PUBLIC_APP_DOWNLOAD_URL=
