rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write for authenticated users.
    // Tighten these (e.g. by yearbookId or resource.data) for production.
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    match /yearbooks/{yearbookId} {
      allow read, write: if request.auth != null;
    }
    match /yearbookMembers/{memberId} {
      allow read, write: if request.auth != null;
    }
    match /prompts/{promptId} {
      allow read, write: if request.auth != null;
    }
    match /drafts/{draftId} {
      allow read, write: if request.auth != null;
    }
    match /polls/{pollId} {
      allow read, write: if request.auth != null;
    }
    match /pollVotes/{voteId} {
      allow read, write: if request.auth != null;
    }
    match /superlatives/{superlativeId} {
      allow read, write: if request.auth != null;
    }
    match /travels/{travelId} {
      allow read, write: if request.auth != null;
    }
  }
}
